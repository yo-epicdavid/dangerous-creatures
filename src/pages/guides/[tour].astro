---
import Layout from '../../layouts/Layout.astro';
import Topbar from '../../components/Topbar.astro';
import CreatureCard from '../../components/CreatureCard.astro';
import { readJSON, asset } from '../../lib/data.js';

export function getStaticPaths() {
  return readJSON('guides.json').map((g) => ({ params: { tour: String(g.tour) }, props: { g } }));
}
const { g } = Astro.props;
const narration = (g.narration || []).map((n) => asset(n));
---
<Layout title={`${g.title} — Guided Tours`} desc={g.intro}>
  <Topbar>
    <a slot="right" class="btn" href="/guides"><span class="arrow" aria-hidden="true">←</span> All tours</a>
  </Topbar>

  <main id="main-content" class="wrap" tabindex="-1">
    <div class="player">
      <h1>{g.title}</h1>
      <p class="host-line">Narrated by {g.host}</p>
      <div class="player__art"><img src={asset(g.art)} alt={g.title} /></div>

      <div class="narrate-bar" role="group" aria-label="Narration player">
        <button class="icon-btn" id="prev" aria-label="Previous step"><span aria-hidden="true">⏮</span></button>
        <button class="icon-btn" id="play" aria-label="Play narration" aria-pressed="false"><span class="play-glyph" aria-hidden="true">▶</span></button>
        <button class="icon-btn" id="next" aria-label="Next step"><span aria-hidden="true">⏭</span></button>
        <span class="step" id="step">Step 1 of {narration.length}</span>
        <progress id="prog" max={narration.length} value="1" aria-label="Tour progress"></progress>
      </div>

      <p class="player__intro">{g.intro}</p>

      {g.creatures?.length > 0 && (
        <>
          <h2 class="section-head">Creatures on this journey</h2>
          <div class="grid">{g.creatures.map((a) => <CreatureCard id={a.id} name={a.name} thumb={a.thumb} />)}</div>
        </>
      )}
    </div>
  </main>

  <audio id="player-audio" preload="none"></audio>

  <script define:vars={{ narration }}>
    const audio = document.getElementById('player-audio');
    const playBtn = document.getElementById('play');
    const playGlyph = playBtn.querySelector('.play-glyph');
    const stepLbl = document.getElementById('step');
    const prog = document.getElementById('prog');
    let step = 0;
    function setPlayState(playing) {
      playGlyph.textContent = playing ? '❚❚' : '▶';
      playBtn.setAttribute('aria-label', playing ? 'Pause narration' : 'Play narration');
      playBtn.setAttribute('aria-pressed', playing ? 'true' : 'false');
    }
    function setStep(i, autoplay) {
      step = Math.max(0, Math.min(i, narration.length - 1));
      audio.src = narration[step];
      stepLbl.textContent = `Step ${step + 1} of ${narration.length}`;
      prog.value = step + 1;
      if (autoplay) audio.play();
    }
    playBtn.addEventListener('click', () => { audio.paused ? audio.play() : audio.pause(); });
    document.getElementById('prev').addEventListener('click', () => setStep(step - 1, true));
    document.getElementById('next').addEventListener('click', () => setStep(step + 1, true));
    audio.addEventListener('play', () => setPlayState(true));
    audio.addEventListener('pause', () => setPlayState(false));
    audio.addEventListener('ended', () => { if (step < narration.length - 1) setStep(step + 1, true); else setPlayState(false); });
    if (narration.length) setStep(0, false);
  </script>
</Layout>

<style>
  .player { max-width: 880px; margin: 8px auto 70px; }
  .player__art { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line); box-shadow: var(--shadow); background: #0c0a08; }
  .player__art img { width: 100%; display: block; }
  .player h1 { font-family: var(--font-display); font-size: clamp(30px, 5vw, 48px); margin: 18px 0 2px; }
  .host-line { color: var(--gold); font-weight: 600; margin: 0 0 4px; }
  .narrate-bar { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--line); border-radius: 16px; padding: 14px 18px; margin: 18px 0; box-shadow: var(--shadow); }
  .narrate-bar .step { color: var(--ink-soft); font-size: 14px; min-width: 92px; }
  .narrate-bar progress { flex: 1; height: 8px; min-width: 120px; accent-color: var(--rust); }
  .icon-btn { appearance: none; cursor: pointer; border: 2px solid #ffffff22; background: var(--panel-2); color: var(--ink); width: 58px; height: 58px; border-radius: 50%; font-size: 24px; transition: .15s; display: inline-flex; align-items: center; justify-content: center; line-height: 1; }
  .icon-btn:hover { border-color: var(--gold); transform: translateY(-1px); }
  /* The play/pause control is the star: big, red and obviously "press me",
     and it turns green while it's playing so kids know it worked. */
  #play { width: 78px; height: 78px; font-size: 32px; background: var(--rust); border-color: transparent; color: #fff; box-shadow: 0 4px 14px #0006; }
  #play:hover { background: #e0613a; border-color: transparent; }
  #play[aria-pressed="true"] { background: var(--green); }
  .player__intro { font-size: 19px; color: var(--ink); }
</style>
