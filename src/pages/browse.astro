---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/Topbar.astro';
import CreatureCard from '../components/CreatureCard.astro';
import { readJSON, catSlug } from '../lib/data.js';
const browse = readJSON('browse.json');
const TABS = [
  { key: 'regions', label: '🌍 By Region', sub: 'Where in the world each creature lives' },
  { key: 'habitats', label: '🌿 By Habitat', sub: 'The kind of place each creature calls home' },
  { key: 'weapons', label: '⚔️ By Weapon', sub: 'How each creature attacks or defends — many have more than one' },
];
---
<Layout title="Explore — Dangerous Creatures" desc="Browse the dangerous creatures by region, habitat, or weapon.">
  <Topbar>
    <a slot="right" class="btn" href="/"><span class="arrow" aria-hidden="true">←</span> All creatures</a>
  </Topbar>

  <div class="browse-head">
    <h1>Explore</h1>
    <div class="tabs">
      <div class="modeswitch" id="tabs" role="group" aria-label="Browse mode">
        {TABS.map((t) => <button data-tab={t.key} aria-pressed="false">{t.label}</button>)}
      </div>
    </div>
  </div>

  <main id="main-content" class="wrap" tabindex="-1">
    {TABS.map((t) => (
      <section class="tabpanel" data-tab={t.key} hidden={t.key !== 'regions'}>
        <p class="sub">{t.sub}</p>
        {browse[t.key].map((c) => (
          <section class="catgroup" id={catSlug(c.category)}>
            <div class="cat-title"><h2>{c.category}</h2><span class="count">{c.count} creature{c.count !== 1 ? 's' : ''}</span></div>
            <div class="grid">{c.animals.map((a) => <CreatureCard id={a.id} name={a.name} thumb={a.thumb} />)}</div>
          </section>
        ))}
      </section>
    ))}
  </main>

  <script>
    const params = new URLSearchParams(location.search);
    const valid = ['regions', 'habitats', 'weapons'];
    let tab = valid.includes(params.get('tab')) ? params.get('tab') : 'regions';
    const panels = document.querySelectorAll('.tabpanel');
    const btns = document.querySelectorAll('#tabs button');
    function setTab(t, scroll) {
      tab = valid.includes(t) ? t : 'regions';
      panels.forEach((p) => (p.hidden = p.dataset.tab !== tab));
      btns.forEach((b) => {
        const active = b.dataset.tab === tab;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      history.replaceState(null, '', `?tab=${tab}${location.hash}`);
      document.title = { regions: 'By Region', habitats: 'By Habitat', weapons: 'By Weapon' }[tab] + ' — Dangerous Creatures';
      if (scroll && location.hash) {
        const el = document.getElementById(location.hash.slice(1));
        if (el) el.scrollIntoView({ behavior: 'smooth' });
      }
    }
    btns.forEach((b) => b.addEventListener('click', () => setTab(b.dataset.tab, false)));
    setTab(tab, true);
  </script>
</Layout>

<style>
  .browse-head { text-align: center; padding: 26px 20px 4px; }
  .browse-head h1 { font-family: var(--font-display); font-size: clamp(32px, 6vw, 56px); margin: 0; }
  .tabs { display: flex; justify-content: center; margin: 18px 0 10px; }
  .sub { text-align: center; color: var(--ink-soft); font-size: 18px; margin: 0 0 10px; }
  .catgroup { margin: 34px 0; scroll-margin-top: 74px; }
  .cat-title { display: flex; align-items: baseline; gap: 12px; margin: 0 0 16px; border-bottom: 1px solid var(--line); padding-bottom: 8px; }
  .cat-title h2 { font-family: var(--font-display); color: var(--gold); font-size: 26px; margin: 0; }
  .cat-title .count { color: var(--ink-soft); font-size: 14px; }
</style>
