  .article .dek { font-size: 21px; color: var(--gold); margin: 0 0 10px; }
  .article h2 { font-family: var(--font-display); color: var(--gold); font-size: clamp(26px, 4vw, 34px); margin: 48px 0 6px; line-height: 1.1; }
