---
import GuideView from '../../components/GuideView.astro';
import { readJSON } from '../../lib/data.js';

export function getStaticPaths() {
  return readJSON('guides.json', 'en').map((g) => ({ params: { host: g.id }, props: { g } }));
}
const { g } = Astro.props;
---
<GuideView g={g} locale="en" />
