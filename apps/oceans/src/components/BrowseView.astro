---
import Layout from '../layouts/Layout.astro';
import Topbar from './Topbar.astro';
import EntryCard from './EntryCard.astro';
import { readJSON, catSlug, lp } from '../lib/data.js';
import { t } from '../i18n/ui.js';

const { locale = 'en' } = Astro.props;
const ui = t(locale);
const browse = readJSON('browse.json', locale);
const TABS = [
  { key: 'categories', label: ui.tabs.categories.label, sub: ui.tabs.categories.sub },
  { key: 'zones', label: ui.tabs.zones.label, sub: ui.tabs.zones.sub },
  { key: 'oceans', label: ui.tabs.oceans.label, sub: ui.tabs.oceans.sub },
];
const altHref = locale === 'es' ? '/browse' : '/es/browse';
const STR = { docTitle: ui.docTitle, suffix: locale === 'es' ? 'Océanos de Microsoft' : 'Microsoft Oceans' };
---
<Layout title={ui.browseTitle} desc={ui.siteTagline} lang={locale} bilingual={true}>
  <Topbar brandHref={lp(locale, '/')} locale={locale} altHref={altHref}>
    <a slot="right" class="btn" href={lp(locale, '/')}><span class="arrow" aria-hidden="true">←</span> {ui.allTopics}</a>
  </Topbar>

  <div class="browse-head">
    <h1>{ui.explore}</h1>
    <div class="tabs">
      <div class="modeswitch" id="tabs" role="group" aria-label="Browse mode">
        {TABS.map((tb) => <button data-tab={tb.key} aria-pressed="false">{tb.label}</button>)}
      </div>
    </div>
  </div>

  <main id="main-content" class="wrap" tabindex="-1">
    {TABS.map((tb) => (
      <section class="tabpanel" data-tab={tb.key} hidden={tb.key !== 'categories'}>
        <p class="sub">{tb.sub}</p>
        {(browse[tb.key] || []).map((c) => (
          <section class="catgroup" id={catSlug(c.key)}>
            <div class="cat-title"><h2>{c.label}</h2><span class="count">{ui.topicCount(c.count)}</span></div>
            <div class="grid">{c.items.map((a) => <EntryCard id={a.id} name={a.name} thumb={a.thumb} locale={locale} />)}</div>
          </section>
        ))}
      </section>
    ))}
  </main>

  <script type="application/json" id="browse-data" set:html={JSON.stringify(STR).replace(/</g, '\\u003c')}></script>
  <script>
    import { initBrowseTabs } from '@ms/site-kit/browse-tabs.js';
    const d = document.getElementById('browse-data');
    initBrowseTabs(d ? JSON.parse(d.textContent) : {});
  </script>
</Layout>

<style>
  .browse-head { text-align: center; padding: 26px 20px 4px; }
  .browse-head h1 { font-family: var(--font-display); font-size: clamp(32px, 6vw, 56px); margin: 0; }
  .tabs { display: flex; justify-content: center; margin: 18px 0 10px; }
  .sub { text-align: center; color: var(--ink-soft); font-size: 18px; margin: 0 0 10px; }
  .catgroup { margin: 34px 0; scroll-margin-top: 74px; }
  .cat-title { display: flex; align-items: baseline; gap: 12px; margin: 0 0 16px; border-bottom: 1px solid var(--line); padding-bottom: 8px; }
  .cat-title h2 { font-family: var(--font-display); color: var(--gold); font-size: 26px; margin: 0; }
  .cat-title .count { color: var(--ink-soft); font-size: 14px; }
</style>
