---
import Layout from '../../layouts/Layout.astro';
import Topbar from '../../components/Topbar.astro';
import { readJSON } from '../../lib/data.js';
const guides = readJSON('guides.json');
---
<Layout title="Guided Tours — Microsoft Dinosaurs" desc="Sixteen narrated tours through the world of the dinosaurs.">
  <Topbar>
    <a slot="right" class="btn" href="/"><span class="arrow" aria-hidden="true">←</span> All dinosaurs</a>
  </Topbar>

  <div class="guides-head">
    <h1>Guided Tours</h1>
    <p>Sixteen narrated journeys through the prehistoric world — pick one and let your guide show you around.</p>
  </div>

  <main id="main-content" class="wrap" tabindex="-1">
    <div class="guide-grid">
      {guides.map((g) => (
        <a class="guidecard" href={`/guides/${g.id}`}>
          <span class="gicon" aria-hidden="true">{g.icon}</span>
          <span class="gtitle">{g.title}</span>
          <span class="gblurb">{g.blurb}</span>
          <span class="gsteps">{g.stepCount} stops</span>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .guides-head { text-align: center; padding: 26px 20px 4px; }
  .guides-head h1 { font-family: var(--font-display); font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .guides-head p { color: var(--ink-soft); margin: 10px auto 0; font-size: 18px; max-width: 640px; }
  .guide-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; margin: 28px 0 70px; }
  .guidecard { display: flex; flex-direction: column; align-items: flex-start; gap: 6px; background: linear-gradient(180deg, var(--panel), var(--panel-2)); border: 1px solid var(--line); border-radius: var(--radius); padding: 20px; text-decoration: none; color: var(--ink); box-shadow: var(--shadow); transition: transform .15s, border-color .15s; }
  .guidecard:hover { transform: translateY(-3px); border-color: var(--gold); }
  .gicon { font-size: 34px; line-height: 1; }
  .gtitle { font-family: var(--font-display); font-weight: 700; font-size: 21px; }
  .gblurb { color: var(--ink-soft); font-size: 14px; line-height: 1.45; flex: 1; }
  .gsteps { color: var(--gold); font-weight: 600; font-size: 13px; }
</style>
