---
import Layout from '../layouts/Layout.astro';
import EntryCard from '../components/EntryCard.astro';
import { readJSON } from '../lib/data.js';
const browse = readJSON('browse.json');
const categories = browse.categories || [];
const total = readJSON('index.json').length;
---
<Layout title="Microsoft Dinosaurs — reborn">
  <main id="main-content" class="wrap" tabindex="-1">
    <div class="cover">
      <h1><b>Microsoft</b><br />Dinosaurs</h1>
      <p>The 1993 dinosaur explorer, reborn for the web — roam the prehistoric world and meet
        {total} dinosaurs, ancient creatures, and the science behind them.</p>
      <nav class="explore-nav" aria-label="Explore Dinosaurs">
        <a class="btn" href="/browse?tab=periods"><span class="arrow" aria-hidden="true">⏳</span> By Period</a>
        <a class="btn" href="/browse?tab=diets"><span class="arrow" aria-hidden="true">🍖</span> By Diet</a>
        <a class="btn btn--play" href="/guides"><span class="arrow" aria-hidden="true">🧭</span> Guided Tours</a>
        <a class="btn btn--play" href="/games"><span class="arrow" aria-hidden="true">🦕</span> Dino Riddles</a>
      </nav>
    </div>

    {categories.map((cat) => (
      <section class="catsection">
        <h2 class="section-head" id={cat.key}>{cat.label} <span class="count">{cat.count}</span></h2>
        <div class="grid">
          {cat.items.map((c) => <EntryCard id={c.id} name={c.name} thumb={c.thumb} />)}
        </div>
      </section>
    ))}

    <footer class="sitefoot">
      <p class="siblings">More worlds to explore:
        <a href="https://dangerous-creatures.pages.dev"><span aria-hidden="true">🦁</span> Dangerous Creatures</a> ·
        <a href="https://oceans-2s9.pages.dev"><span aria-hidden="true">🌊</span> Oceans</a>
      </p>
      <p class="links"><a href="/making-of"><span aria-hidden="true">✦</span> The Making Of</a> &nbsp;·&nbsp; <a href="/credits">Credits &amp; Acknowledgements</a></p>
      <p class="notice">
        A non-commercial, educational fan preservation of <i>Microsoft Dinosaurs</i> (1993).
        Not affiliated with Microsoft. All original media © their respective owners —
        <a href="/credits">see credits</a>.
      </p>
    </footer>
  </main>
</Layout>

<style>
  .cover { text-align: center; padding: 56px 20px 14px; }
  .cover h1 { font-family: var(--font-display); font-size: clamp(44px, 8.5vw, 92px); margin: 0; line-height: .95; font-weight: 700; }
  .cover h1 b { color: var(--rust); }
  .cover p { color: var(--ink-soft); font-size: 20px; max-width: 660px; margin: 14px auto 18px; }
  .catsection { margin: 6px 0 38px; }
  .section-head .count { color: var(--ink-soft); font-size: .6em; font-weight: 600; vertical-align: middle; }
  .grid { margin: 10px 0 0; }
  .sitefoot { text-align: center; padding: 6px 20px 70px; color: var(--ink-soft); }
  .sitefoot .links { margin: 0 0 12px; font-size: 16px; }
  .sitefoot .links a { color: var(--gold); }
  .sitefoot .notice { margin: 0 auto; font-size: 13px; max-width: 660px; line-height: 1.5; }
  .sitefoot .notice a { color: var(--ink-soft); text-decoration: underline; }
</style>
