---
import Layout from '../../layouts/Layout.astro';
import Topbar from '../../components/Topbar.astro';
import { listEntries, asset } from '../../lib/data.js';

export function getStaticPaths() {
  return listEntries().map((d) => ({ params: { id: d.id }, props: { d } }));
}
const { d } = Astro.props;
const facts = d.facts || [];
const CAT_LABEL = { dinosaur: 'Dinosaur', creature: 'Prehistoric creature', concept: 'Dinosaur science' };
const catLabel = CAT_LABEL[d.category] || 'Dinosaur';
const PERIODS = ['Triassic', 'Jurassic', 'Cretaceous'];
const periodGroup = PERIODS.find((p) => (d.period || '').toLowerCase().includes(p.toLowerCase()));
const crosslinks = (d.crosslinks || []).filter((c) => c.to);
const ogImage = `/assets/${d.id}/og.jpg`;
---
<Layout title={`${d.name} — Microsoft Dinosaurs`} desc={d.tagline} ogImage={ogImage}>
  <Topbar>
    <div slot="center" class="modeswitch" id="modeswitch" role="group" aria-label="View mode">
      <button data-mode="modern" aria-pressed="true">Modern</button>
      <button data-mode="classic" aria-pressed="false">Classic 1993</button>
    </div>
  </Topbar>

  <main id="main-content" class="wrap" tabindex="-1">
    <!-- MODERN (pre-rendered) -->
    <div id="modern">
      <section class="hero">
        <div class="hero__media">
          <img src={asset(d.hero.image)} alt={d.hero.alt || d.name} />
          <hgroup class="hero__title">
            <div class="name">{d.name}</div>
            {d.scientificName && <div class="sci">{d.scientificName}</div>}
          </hgroup>
        </div>
      </section>

      {(d.pronunciation || d.sayIt || d.meaning) && (
        <p class="dino-meta">
          {d.pronunciation && <span class="pron">{d.pronunciation}</span>}
          {d.sayIt && <button class="mini-listen say" id="say-it" aria-label={`Say ${d.name}`}>🔊 Say it</button>}
          {d.meaning && <span class="meaning">name means “{d.meaning}”</span>}
        </p>
      )}

      <p class="tagline">{d.tagline}</p>

      {(d.narration || d.sound) && (
        <p class="hear-row">
          {d.narration && <button class="mini-listen" data-listen={asset(d.narration)} aria-label={`Listen to the ${d.name} summary`}><span class="arrow" aria-hidden="true">▶</span> Listen</button>}
          {d.sound && <button class="mini-listen sound" id="hear-sound" aria-label="Hear the scene sound">🔊 Hear it</button>}
        </p>
      )}

      <div class="chips">
        <span class="chips__label">Kind</span><a class="chip" href={`/browse?tab=categories#${d.category}`}>{catLabel}</a>
        {d.period && <span class="chips__label">Period</span>}
        {d.period && (periodGroup
          ? <a class="chip" href={`/browse?tab=periods#${periodGroup.toLowerCase()}`}>{d.period}</a>
          : <span class="chip">{d.period}</span>)}
        {d.diet && <span class="chips__label">Diet</span>}
        {d.diet && <a class="chip" href={`/browse?tab=diets#${d.diet.toLowerCase()}`}>{d.diet}</a>}
      </div>

      <div class="layout">
        <div class="intro"><p class="lead">{d.intro}</p></div>
        {facts.length > 0 && (
          <aside class="factcard">
            <h2>Fast facts</h2>
            <dl>
              {facts.map((f) => (
                <div>
                  <dt>{f.label}</dt>
                  <dd>{f.value}</dd>
                </div>
              ))}
            </dl>
          </aside>
        )}
      </div>

      {d.topics?.length > 0 && (
        <>
          <h2 class="section-head">Explore</h2>
          <div class="topics">
            {d.topics.map((t) => (
              <article class="topic">
                <div class="topic__media"><img src={asset(t.image)} alt={t.title} loading="lazy" /></div>
                <div class="topic__body">
                  <h3>{t.title}</h3>
                  <p>{t.text}</p>
                  {t.captions?.length > 0 && (
                    <div class="topic__captions">
                      {t.captions.map((c) => <div class="cap"><b>{c.label}</b>{c.text}</div>)}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </>
      )}

      {crosslinks.length > 0 && (
        <>
          <h2 class="section-head">Explore more</h2>
          <div class="chips">
            {crosslinks.map((c) => <a class="chip" href={`/dino/${c.to}`}>{c.label} <span class="arrow" aria-hidden="true">→</span></a>)}
          </div>
        </>
      )}

      {d._provenance && (
        <p class="prov"><b>Source: </b>{d._provenance.source}. {d._provenance.note}
          {' '}<a href="/credits">Credits &amp; Acknowledgements <span class="arrow" aria-hidden="true">→</span></a></p>
      )}
    </div>

    <!-- CLASSIC 1993 (interactive island, built client-side from the same data) -->
    <div id="classic" hidden></div>
  </main>

  <script define:vars={{ data: d }}>
    const params = new URLSearchParams(location.search);
    const MODE_KEY = 'dino-mode';
    let mode = params.get('mode') || localStorage.getItem(MODE_KEY) || 'modern';
    const el = (t, p = {}, ...k) => { const n = Object.assign(document.createElement(t), p); for (const c of k) n.append(c); return n; };
    const asset = (p) => (!p ? p : p.startsWith('/') ? p : '/' + p);
    const modern = document.getElementById('modern');
    const classicEl = document.getElementById('classic');

    document.querySelectorAll('#modeswitch button').forEach((b) =>
      b.addEventListener('click', () => setMode(b.dataset.mode)));
    function setMode(m) { mode = (m === 'classic' && data.classic) ? 'classic' : 'modern'; localStorage.setItem(MODE_KEY, mode); apply(); }
    function apply() {
      document.body.dataset.mode = mode;
      document.querySelectorAll('#modeswitch button').forEach((b) => {
        const active = b.dataset.mode === mode;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      const isClassic = mode === 'classic' && !!data.classic;
      modern.hidden = isClassic;
      classicEl.hidden = !isClassic;
      if (isClassic && !classicEl.dataset.rendered) { renderClassic(); classicEl.dataset.rendered = '1'; }
      scrollTo({ top: 0 });
    }

    // name pronunciation (AUDPRON) — the "Say it" button
    const sayIt = data.sayIt ? new Audio(asset(data.sayIt)) : null;
    const sayBtn = document.getElementById('say-it');
    if (sayBtn && sayIt) sayBtn.addEventListener('click', () => {
      if (clipBtn && !clip.paused) { clip.pause(); clearClip(); }
      if (sound) sound.pause();
      sayIt.currentTime = 0; sayIt.play().catch(() => {});
    });

    // dramatic scene sound (AUDSCENE) — the "Hear it" button
    const sound = data.sound ? new Audio(asset(data.sound)) : null;
    const hearBtn = document.getElementById('hear-sound');
    if (hearBtn && sound) hearBtn.addEventListener('click', () => {
      if (clipBtn && !clip.paused) { clip.pause(); clearClip(); }
      if (sayIt) sayIt.pause();
      sound.currentTime = 0; sound.play().catch(() => {});
    });

    function renderClassic() {
      const c = data.classic;
      classicEl.innerHTML = '';
      const root = el('div', { className: 'classic' });
      const bar = el('div', { className: 'classic__bar' });
      bar.append(el('div', { className: 'classic__title', textContent: `${data.name} — original 1993 screens` }));
      const reveal = el('button', { className: 'btn', textContent: 'Show clickable spots' });
      bar.append(reveal);
      root.append(bar);
      const stage = el('div', { className: 'classic__stage' });
      root.append(stage);
      classicEl.append(root);
      reveal.addEventListener('click', () => { const on = stage.classList.toggle('reveal'); reveal.textContent = on ? 'Hide clickable spots' : 'Show clickable spots'; });
      if (params.get('spots') === '1') { stage.classList.add('reveal'); reveal.textContent = 'Hide clickable spots'; }
      const history = [];
      function show(key) {
        const sc = c.screens[key];
        if (!sc) return;
        stage.innerHTML = '';
        const frame = el('div', { className: 'classic__frame' });
        frame.append(el('img', { className: 'classic__screen', src: asset(sc.image), alt: `${data.name} — ${key}` }));
        for (const h of sc.hotspots || []) {
          const b = el('button', { className: 'hotspot', title: h.label, ariaLabel: h.label });
          Object.assign(b.style, { left: h.x + '%', top: h.y + '%', width: h.w + '%', height: h.h + '%' });
          if (h.disabled) b.classList.add('hotspot--disabled');
          if (h.external) b.classList.add('hotspot--link');
          const tip = el('span', { className: 'hotspot__tip', textContent: h.label });
          if (h.external) tip.append(el('span', { className: 'arrow', textContent: ' →', ariaHidden: 'true' }));
          b.append(tip);
          b.addEventListener('click', () => {
            if (h.external) { location.href = '/dino/' + h.external + (mode === 'classic' ? '?mode=classic' : ''); return; }
            if (h.disabled) return;
            if (h.to) { history.push(key); show(h.to); }
          });
          frame.append(b);
        }
        stage.append(frame);
        if (key !== c.start) {
          const back = el('button', { className: 'classic__back btn', innerHTML: '<span class="arrow" aria-hidden="true">‹</span> Back' });
          back.addEventListener('click', () => show(history.pop() || c.start));
          stage.append(back);
        }
      }
      show(c.start);
    }

    // short-clip player: the scene narration ("Listen")
    const clip = new Audio();
    let clipBtn = null;
    const clearClip = () => { if (clipBtn) clipBtn.classList.remove('playing'); clipBtn = null; };
    clip.addEventListener('ended', clearClip);
    document.querySelectorAll('[data-listen]').forEach((b) => {
      b.addEventListener('click', () => {
        if (clipBtn === b && !clip.paused) { clip.pause(); clearClip(); return; }
        if (sayIt) sayIt.pause();
        if (sound) sound.pause();
        if (clipBtn) clipBtn.classList.remove('playing');
        clip.src = b.getAttribute('data-listen');
        clip.play().catch(() => {});
        clipBtn = b; b.classList.add('playing');
      });
    });

    apply();
  </script>
</Layout>

<style>
  .dino-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 10px 14px; margin: 16px 0 2px; }
  .dino-meta .pron { font-size: 18px; color: var(--gold); font-weight: 600; letter-spacing: .3px; }
  .dino-meta .meaning { color: var(--ink-soft); font-style: italic; }
  .mini-listen.say { background: var(--green); border-color: var(--green); color: #0e1408; }
</style>
