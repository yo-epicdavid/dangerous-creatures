---
import '../../../../packages/site-kit/base.css';
import '../../web/styles.css';
import { t } from '../i18n/ui.js';
const {
  title = 'Microsoft Dinosaurs',
  desc = 'The 1993 dinosaur explorer, reborn for the web — so any kid can roam the prehistoric world and its creatures.',
  ogImage = '/og-cover.jpg',
  lang = 'en',
  bilingual = false,
} = Astro.props;
const ui = t(lang);
const ogImageUrl = new URL(ogImage, Astro.site).href;

// hreflang alternates — only for pages that exist in both locales (home, dino, browse).
const p = Astro.url.pathname;
const enPath = (p === '/es' || p === '/es/' || p.startsWith('/es/')) ? (p.replace(/^\/es/, '') || '/') : p;
const esPath = enPath === '/' ? '/es/' : '/es' + enPath;
const enUrl = new URL(enPath, Astro.site).href;
const esUrl = new URL(esPath, Astro.site).href;
---
<!doctype html>
<html lang={ui.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <!-- Tint the mobile browser chrome to match the prehistoric earth background. -->
    <meta name="theme-color" content="#16120c" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {bilingual && (
      <>
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="es" href={esUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />
      </>
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{ui.skip}</a>
    <slot />

    <dialog id="lightbox" class="lightbox" aria-label={lang === 'es' ? 'Visor de imagen' : 'Image viewer'}>
      <button type="button" class="lightbox__close" data-lightbox-close aria-label={lang === 'es' ? 'Cerrar' : 'Close'}>✕</button>
      <img class="lightbox__img" alt="" />
    </dialog>
    <script>
      // Tap any [data-zoomable] image to view it full-screen in a native <dialog> (free focus
      // trap + Esc-to-close). Backdrop click or the ✕ closes it; clicking the image does not.
      (() => {
        const lb = document.getElementById('lightbox');
        if (!lb || typeof lb.showModal !== 'function') return;
        const img = lb.querySelector('.lightbox__img');
        document.addEventListener('click', (e) => {
          const z = e.target.closest('[data-zoomable]');
          if (!z) return;
          const im = z.tagName === 'IMG' ? z : z.querySelector('img');
          if (!im) return;
          e.preventDefault();
          img.src = im.currentSrc || im.src;
          img.alt = im.alt || '';
          lb.showModal();
        });
        lb.addEventListener('click', (e) => {
          if (e.target === lb || e.target.closest('[data-lightbox-close]')) lb.close();
        });
        lb.addEventListener('close', () => { img.removeAttribute('src'); });
      })();
    </script>
  </body>
</html>
