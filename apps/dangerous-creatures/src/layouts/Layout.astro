---
import '../../../../packages/site-kit/base.css';
import '../../web/styles.css';
import { t } from '../i18n/ui.js';
const {
  title = 'Dangerous Creatures',
  desc = 'The classic 1994 wildlife explorer, reborn for the web — so any kid can meet the planet’s most fascinating animals.',
  lang = 'en',
  bilingual = false,
} = Astro.props;
const ui = t(lang);
const ogImage = new URL('/og-cover.jpg', Astro.site).href;

// hreflang alternates — only for pages that exist in both locales (home, animal, browse).
const p = Astro.url.pathname;
const enPath = (p === '/es' || p === '/es/' || p.startsWith('/es/')) ? (p.replace(/^\/es/, '') || '/') : p;
const esPath = enPath === '/' ? '/es/' : '/es' + enPath;
const enUrl = new URL(enPath, Astro.site).href;
const esUrl = new URL(esPath, Astro.site).href;
---
<!doctype html>
<html lang={ui.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <!-- Tint the mobile browser chrome (iOS Safari address bar / notch area,
         Android Chrome toolbar) to match the site's dark background. -->
    <meta name="theme-color" content="#1b1714" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {bilingual && (
      <>
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="es" href={esUrl} />
        <link rel="alternate" hreflang="x-default" href={enUrl} />
      </>
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{ui.skip}</a>
    <slot />
  </body>
</html>
