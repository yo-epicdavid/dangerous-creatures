---
import GuideView from '../../../components/GuideView.astro';
import { readJSON } from '../../../lib/data.js';

export function getStaticPaths() {
  return readJSON('guides.json', 'es').map((g) => ({ params: { tour: String(g.tour) }, props: { g } }));
}
const { g } = Astro.props;
---
<GuideView g={g} locale="es" />
