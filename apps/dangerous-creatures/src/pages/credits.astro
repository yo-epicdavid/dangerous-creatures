---
import Layout from '../layouts/Layout.astro';
import Topbar from '../components/Topbar.astro';
import { readJSON } from '../lib/data.js';
const d = readJSON('credits.json');
---
<Layout title="Credits & Acknowledgements — Dangerous Creatures" desc="With thanks to the photographers, filmmakers, and agencies who captured these creatures.">
  <Topbar>
    <a slot="right" class="btn" href="/"><span class="arrow" aria-hidden="true">←</span> Home</a>
  </Topbar>

  <main id="main-content" class="credits" tabindex="-1">
    <p class="kicker">Credits & Acknowledgements</p>
    <h1>With thanks to the people who captured these creatures</h1>
    <p>This is a <b>non-commercial, educational preservation</b> of <i>Microsoft Dangerous Creatures</i> (1994),
       rebuilt for the modern web so a new generation of kids can explore it. Every photograph, film clip, and
       article was created by the photographers, filmmakers, writers, and agencies credited below. We're deeply
       grateful for their work — this project exists only to keep it alive and accessible.</p>

    <div class="notice">
      <p style="margin:0 0 8px"><b>Please note.</b> This is a fan-made educational project. It is <b>not affiliated
      with, endorsed by, or sponsored by Microsoft Corporation</b>. All original images, video, audio, and text
      remain &copy; their respective owners (Microsoft and the photographers/agencies listed here). No money is made
      from this site — there are no ads, sales, or donations.</p>
      <p style="margin:0">If you are a rights holder and would like your work credited differently or removed,
      please get in touch and we'll act promptly.</p>
    </div>

    <h2>The original</h2>
    <p>{d.source}</p>

    <h2>Photography & Footage</h2>
    <p>Images and film clips courtesy of <span class="agencies">{d.agencies.join(' · ')}</span> — and the many
       individual photographers and filmmakers below:</p>
    <div class="creditlist">{d.credits.map((c) => <div>{c}</div>)}</div>

    <h2>Reference Works</h2>
    <p>Facts and articles drew on these reference titles:</p>
    <ul class="reflist">{d.referenceWorks.map((r) => <li>{r}</li>)}</ul>

    <h2>The recreation</h2>
    <p>Asset restoration, text liberation, and the modern rebuild were done with care as a tribute to the original.
       Title set in Papyrus, in homage to the era. 🦁</p>
    <a class="btn" href="/" style="margin-top:20px"><span class="arrow" aria-hidden="true">←</span> Back to the creatures</a>
  </main>
</Layout>

<style>
  .credits { max-width: 820px; margin: 0 auto; padding: 0 22px 90px; }
  .credits .kicker { text-transform: uppercase; letter-spacing: 3px; font-size: 13px; color: var(--ink-soft); margin-top: 40px; }
  .credits h1 { font-family: var(--font-display); font-weight: 700; font-size: clamp(34px, 6vw, 60px); margin: 6px 0 10px; }
  .credits h2 { font-family: var(--font-display); color: var(--gold); font-size: 26px; margin: 40px 0 10px; }
  .credits p { font-size: 18px; }
  .notice { border: 1px solid var(--gold); background: #e8a33d12; border-radius: 14px; padding: 18px 20px; margin: 22px 0; }
  .notice b { color: var(--gold); }
  .agencies { color: var(--ink); font-weight: 600; }
  .creditlist { columns: 240px 3; column-gap: 26px; font-size: 14px; color: var(--ink-soft); margin-top: 10px; }
  .creditlist div { break-inside: avoid; margin: 0 0 5px; }
  .reflist { color: var(--ink-soft); font-size: 15px; }
  .reflist li { margin: 3px 0; }
</style>
