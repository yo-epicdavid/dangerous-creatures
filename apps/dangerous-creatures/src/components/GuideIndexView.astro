---
import Layout from '../layouts/Layout.astro';
import Topbar from './Topbar.astro';
import { readJSON, asset, lp } from '../lib/data.js';
import { t } from '../i18n/ui.js';

const { locale = 'en' } = Astro.props;
const ui = t(locale);
const guides = readJSON('guides.json', locale);
const altHref = locale === 'es' ? '/guides' : '/es/guides';
---
<Layout title={`${ui.guidedTours} — Dangerous Creatures`} desc={ui.guidesSub} lang={locale} bilingual={true}>
  <Topbar brandHref={lp(locale, '/')} locale={locale} altHref={altHref}>
    <a slot="right" class="btn" href={lp(locale, '/')}><span class="arrow" aria-hidden="true">←</span> {ui.allCreatures}</a>
  </Topbar>

  <div class="guides-head">
    <h1>{ui.guidedTours}</h1>
    <p>{ui.guidesSub}</p>
  </div>

  <main id="main-content" class="wrap" tabindex="-1">
    {ui.guideGroups.map((grp) => {
      const tours = guides.filter((tt) => tt.host === grp.host);
      return tours.length === 0 ? null : (
        <section class="host-group">
          <h2>{grp.label}</h2>
          <div class="grid">
            {tours.map((tt) => (
              <a class="creature tourcard" href={lp(locale, `/guides/${tt.tour}`)}>
                <img src={asset(tt.art)} alt={tt.title} loading="lazy" />
                <span>{tt.title}</span>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Layout>

<style>
  .guides-head { text-align: center; padding: 26px 20px 4px; }
  .guides-head h1 { font-family: var(--font-display); font-size: clamp(34px, 6vw, 60px); margin: 0; }
  .guides-head p { color: var(--ink-soft); margin: 8px 0 0; font-size: 18px; }
  .host-group { margin: 34px 0; }
  .host-group > h2 { font-family: var(--font-display); color: var(--gold); font-size: 24px; border-bottom: 1px solid var(--line); padding-bottom: 8px; margin: 0 0 16px; }
  .tourcard span { font-family: var(--font-display); font-weight: 700; }
</style>
